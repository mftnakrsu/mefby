---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import EssayRow from '../../components/EssayRow.astro';

const all = await getCollection('essays', ({ data }) => !data.draft && !data.isTranslation);

// Numbered series (e.g. the RAG series) reads in part order, ascending; everything
// else follows, newest first. The "New" badge stays on the genuinely newest essay.
const byDateDesc = (a: CollectionEntry<'essays'>, b: CollectionEntry<'essays'>) =>
  b.data.date.getTime() - a.data.date.getTime();
const series = all
  .filter((e) => e.data.seriesOrder != null)
  .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
const rest = all.filter((e) => e.data.seriesOrder == null).sort(byDateDesc);
const essays = [...series, ...rest];
const newestSlug = [...all].sort(byDateDesc)[0]?.slug;
// Count canonicals that have a Turkish counterpart (translations are filtered out above),
// so the bilingual claim stays accurate as more essays get translated.
const bilingualCount = all.filter((e) => e.data.translationSlug).length;
---

<Layout title="Essays — Meftun Akarsu" description="Long-form technical essays.">
  <div class="min-h-screen bg-white text-zinc-500 font-sans">
    <div class="max-w-2xl mx-auto px-6 py-16 md:py-24">
      <a href="/" class="text-xs text-zinc-400 hover:text-emerald-600 transition-colors mb-12 inline-block">&larr; back</a>

      <h1 class="text-2xl font-semibold text-zinc-900 mb-1">Essays</h1>
      <p class="text-sm text-zinc-400 mb-10">{essays.length} essays · {bilingualCount} also in Türkçe</p>

      <a
        href="https://github.com/mftnakrsu/rag-by-hand"
        target="_blank"
        rel="noopener noreferrer"
        class="group mb-8 flex items-center justify-between rounded-lg border border-zinc-200 bg-zinc-50/60 px-4 py-3 transition-colors hover:border-emerald-300 hover:bg-emerald-50/40"
      >
        <span class="text-[13px] text-zinc-600">
          <span class="font-medium text-zinc-900">RAG from First Principles</span> — runnable code &amp; step-by-step notebooks for the {series.length}-part series
        </span>
        <span class="shrink-0 text-[11px] font-mono text-zinc-400 group-hover:text-emerald-600">Code on GitHub &#8599;</span>
      </a>

      <ul class="border-t border-zinc-100">
        {essays.map((essay) => (
          <EssayRow essay={essay} featured={essay.slug === newestSlug} />
        ))}
      </ul>
    </div>
  </div>
</Layout>
