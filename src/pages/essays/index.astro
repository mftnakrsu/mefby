---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import EssayRow from '../../components/EssayRow.astro';

const essays = (await getCollection('essays', ({ data }) => !data.draft && !data.isTranslation))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Essays — Meftun Akarsu" description="Long-form technical essays.">
  <div class="min-h-screen bg-white text-zinc-500 font-sans">
    <div class="max-w-2xl mx-auto px-6 py-16 md:py-24">
      <a href="/" class="text-xs text-zinc-400 hover:text-emerald-600 transition-colors mb-12 inline-block">&larr; back</a>

      <h1 class="text-2xl font-semibold text-zinc-900 mb-1">Essays</h1>
      <p class="text-sm text-zinc-400 mb-10">{essays.length} essays · available in English &amp; Türkçe</p>

      <ul class="border-t border-zinc-100">
        {essays.map((essay, i) => (
          <EssayRow essay={essay} featured={i === 0} />
        ))}
      </ul>
    </div>
  </div>
</Layout>
