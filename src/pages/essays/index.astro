---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const essays = (await getCollection('essays', ({ data }) => !data.draft && !data.isTranslation))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Essays — Meftun Akarsu" description="Long-form technical essays.">
  <div class="min-h-screen bg-white text-zinc-500 font-sans">
    <div class="max-w-2xl mx-auto px-6 py-16 md:py-24">
      <a href="/" class="text-xs text-zinc-400 hover:text-emerald-600 transition-colors mb-12 inline-block">&larr; back</a>

      <h1 class="text-2xl font-semibold text-zinc-900 mb-10">Essays</h1>

      <div class="space-y-8">
        {essays.map(essay => (
          <a href={`/essays/${essay.slug}`} class="block group">
            <div class="flex items-baseline justify-between gap-4 mb-1">
              <h2 class="text-[15px] text-zinc-900 font-medium group-hover:text-emerald-600 transition-colors">{essay.data.title}</h2>
              <span class="text-[11px] text-zinc-400 font-mono shrink-0">{essay.data.date.toISOString().slice(0, 10)}</span>
            </div>
            <p class="text-[13px] text-zinc-500 leading-relaxed">{essay.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
