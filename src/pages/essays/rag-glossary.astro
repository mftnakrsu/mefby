---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const parts = (await getCollection('essays', ({ data }) => !data.draft && data.seriesOrder != null && data.series === 'rag'))
  .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
---

<Layout
  title="RAG Glossary — Meftun Akarsu"
  description="A reference index to every glossary in the RAG from First Principles series: jump straight to the terms defined in each part."
>
  <div class="min-h-screen bg-white text-zinc-500 font-sans">
    <div class="max-w-2xl mx-auto px-6 py-16 md:py-24">
      <a href="/essays/rag" class="text-xs text-zinc-400 hover:text-emerald-600 transition-colors mb-12 inline-block">&larr; back to the series</a>

      <p class="text-[11px] font-mono uppercase tracking-widest text-emerald-700 mb-3">Reference</p>
      <h1 class="text-2xl sm:text-[28px] font-semibold text-zinc-900 leading-[1.25] tracking-tight mb-5">RAG Glossary</h1>
      <p class="text-[15px] text-zinc-600 leading-relaxed mb-12">
        Every part of <a href="/essays/rag" class="text-emerald-700 underline decoration-emerald-200 underline-offset-2 hover:decoration-emerald-500 transition-colors">RAG from First Principles</a>
        ends with a glossary that defines the terms it introduced. This page collects them in one place. Pick a
        part below and you land directly on its glossary, so you can look up a definition without re-reading the prose.
      </p>

      <ol class="border-t border-zinc-100">
        {parts.map((p) => (
          <li class="border-b border-zinc-100">
            <a href={`/essays/${p.slug}#glossary`} class="group flex gap-3 py-4 -mx-2 px-2 rounded-lg transition-colors hover:bg-emerald-50/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/40">
              <span class="shrink-0 mt-0.5 w-7 text-right font-mono text-[11px] text-zinc-400">{p.data.seriesOrder}</span>
              <span class="min-w-0">
                <span class="block text-[15px] font-medium text-zinc-900 group-hover:text-emerald-700 transition-colors">Part {p.data.seriesOrder}: {p.data.title}</span>
                <span class="mt-1 block text-[12px] font-mono text-zinc-500">glossary</span>
              </span>
              <span aria-hidden="true" class="ml-auto self-center pl-2 text-zinc-300 group-hover:text-emerald-600 group-hover:translate-x-0.5 transition-all">&rarr;</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </div>
</Layout>
