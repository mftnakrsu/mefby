---
import Layout from '../layouts/Layout.astro';
import { EXPERIENCE, PROJECTS, PROFILE, PUBLICATIONS, EDUCATION, CERTIFICATIONS, WRITING } from '../../constants';
import { getCollection } from 'astro:content';

const essays = (await getCollection('essays', ({ data }) => !data.draft && !data.isTranslation))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const elsewhere = WRITING.filter((p) => p.url);

// Human-readable date: 2026-06-09 -> "Jun 9, 2026"
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const fmtMaybe = (s: string) => {
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : fmtDate(d);
};

// Reading time from the raw markdown body (~200 wpm), counting prose rather than
// MDX/JSX syntax (imports, <Diagram> blocks, fenced code, markdown punctuation).
const readingTime = (body: string) => {
  const words = body
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/^import\s.+$/gm, ' ')
    .replace(/<[^>]+>/g, ' ')
    .replace(/[#>*_`~\-\[\]()|]/g, ' ')
    .split(/\s+/)
    .filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
};

// Every essay is bilingual; surface its languages EN-first regardless of canonical.
const essayLangs = (lang: 'en' | 'tr', hasTranslation: boolean): string[] =>
  hasTranslation ? ['EN', 'TR'] : [lang.toUpperCase()];

// Drop language-marker tags (already shown by the language badge); keep 3 topics.
const topicTags = (tags: string[]): string[] =>
  tags
    .filter((t) => !['english', 'türkçe', 'turkce', 'turkish'].includes(t.toLowerCase()))
    .slice(0, 3);
---

<Layout>
  <div class="min-h-screen bg-white text-zinc-500 font-sans">
    <div class="max-w-2xl mx-auto px-6 py-16 md:py-24">

      <header class="mb-20">
        <img src="/profile.jpg" alt="Meftun Akarsu" class="w-28 h-28 rounded-full object-cover mb-6 ring-4 ring-emerald-400 ring-offset-4 ring-offset-white" />
        <h1 class="text-2xl font-semibold text-zinc-900 mb-3">Meftun Akarsu</h1>
        <p class="text-base leading-relaxed mb-6">{PROFILE.bio}</p>

        <div class="text-sm space-y-1 mb-6">
          {EDUCATION.map(edu => (
            <p class="text-zinc-500">
              {edu.degree}, {edu.school}{edu.gpa ? ` (${edu.gpa})` : ''}
            </p>
          ))}
        </div>

        <div class="flex flex-wrap gap-4 text-sm">
          {PROFILE.socials.github && (
            <a href={PROFILE.socials.github} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 text-zinc-500 hover:text-emerald-600">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          )}
          {PROFILE.socials.linkedin && (
            <a href={PROFILE.socials.linkedin} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 text-zinc-500 hover:text-emerald-600">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              LinkedIn
            </a>
          )}
          <a href={`mailto:${PROFILE.email}`} class="inline-flex items-center gap-1.5 text-zinc-500 hover:text-emerald-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {PROFILE.email}
          </a>
          <a href="https://medium.com/@meftunakarsu" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 text-zinc-500 hover:text-emerald-600">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
            Blog
          </a>
        </div>
      </header>

      <section class="mb-20">
        <h2 class="text-xs font-medium text-zinc-600 uppercase tracking-widest mb-8">Experience</h2>
        <div class="space-y-6">
          {EXPERIENCE.map(exp => (
            <div class="group">
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-0">
                <span class="text-xs text-zinc-600 sm:w-44 shrink-0 font-mono">{exp.period}</span>
                <div>
                  <span class="text-sm text-zinc-900">{exp.role}</span>
                  <span class="text-sm text-zinc-600"> — {exp.company}</span>
                </div>
              </div>
              <p class="text-xs text-zinc-600 mt-1.5 sm:ml-44 leading-relaxed">{exp.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-xs font-medium text-zinc-600 uppercase tracking-widest mb-8">Selected Work</h2>
        <div class="space-y-8">
          {PROJECTS.map(project => (
            <div>
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="text-sm text-zinc-900 font-medium">{project.title}</h3>
                {project.link && (
                  <a href={project.link} target="_blank" rel="noreferrer" class="text-xs text-zinc-600 hover:text-emerald-600 shrink-0">
                    link &rarr;
                  </a>
                )}
              </div>
              <p class="text-xs text-zinc-500 mt-1.5 leading-relaxed">{project.description}</p>
              <div class="flex flex-wrap gap-x-2 gap-y-1 mt-2">
                {project.tags.map(tag => (
                  <span class="text-[11px] text-zinc-600">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-20" aria-labelledby="writing-heading">
        <h2 id="writing-heading" class="text-xs font-medium text-zinc-600 uppercase tracking-widest mb-8">Writing</h2>

        {/* Essays — refined editorial index, hairline-separated rows */}
        {essays.length > 0 && (
          <div>
            <div class="flex items-center gap-3 mb-4">
              <h3 class="text-[11px] font-medium text-zinc-400 uppercase tracking-widest">Essays</h3>
              <span aria-hidden="true" class="h-px flex-1 bg-zinc-100"></span>
            </div>
            <ul class="border-t border-zinc-100">
              {essays.map((essay, i) => {
                const langs = essayLangs(essay.data.lang, !!essay.data.translationSlug);
                const tags = topicTags(essay.data.tags);
                const isNewest = i === 0;
                return (
                  <li class="border-b border-zinc-100">
                    <a
                      href={`/essays/${essay.slug}`}
                      class={`group block py-5 rounded-lg transition-colors hover:bg-emerald-50/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/40 ${isNewest ? '-ml-2 -mr-2 pl-3 pr-2 rounded-l-none border-l-2 border-emerald-300' : '-mx-2 px-2'}`}
                    >
                      <div class="flex items-baseline gap-2">
                        <h4 class={`font-medium text-zinc-900 leading-snug group-hover:text-emerald-700 transition-colors ${isNewest ? 'text-base' : 'text-[15px]'}`}>
                          {essay.data.title}
                        </h4>
                        {isNewest && (
                          <span class="shrink-0 inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-1.5 py-px text-[10px] font-medium uppercase tracking-wider text-emerald-700">
                            New<span class="sr-only"> — most recent essay</span>
                          </span>
                        )}
                        <span aria-hidden="true" class="ml-auto pl-2 text-zinc-300 group-hover:text-emerald-600 group-hover:translate-x-0.5 transition-all">&rarr;</span>
                      </div>

                      <div class="mt-1.5 flex flex-wrap items-center gap-x-2 gap-y-1 text-[11px] font-mono text-zinc-400">
                        <time datetime={essay.data.date.toISOString().slice(0, 10)}>{fmtDate(essay.data.date)}</time>
                        <span aria-hidden="true" class="text-zinc-300">&middot;</span>
                        <span>{readingTime(essay.body)} min read</span>
                        <span aria-hidden="true" class="text-zinc-300">&middot;</span>
                        <span aria-label={`Available in ${langs.join(' and ')}`}>{langs.join(' · ')}</span>
                      </div>

                      {essay.data.description && (
                        <p class="mt-2 text-[13px] leading-relaxed text-zinc-500 line-clamp-2">
                          {essay.data.description}
                        </p>
                      )}

                      {tags.length > 0 && (
                        <ul class="mt-2.5 flex flex-wrap gap-x-1.5 gap-y-1" aria-label="Topics">
                          {tags.map((tag) => (
                            <li class="text-[10px] font-mono text-zinc-400 group-hover:text-emerald-600/80 transition-colors">#{tag}</li>
                          ))}
                        </ul>
                      )}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )}

        {/* Elsewhere — external writing, an even lighter list */}
        {elsewhere.length > 0 && (
          <div>
            <div class="flex items-center gap-3 mt-10 mb-4">
              <h3 class="text-[11px] font-medium text-zinc-400 uppercase tracking-widest">Elsewhere</h3>
              <span aria-hidden="true" class="h-px flex-1 bg-zinc-100"></span>
            </div>
            <ul class="space-y-3">
              {elsewhere.map((post) => (
                <li>
                  <a
                    href={post.url}
                    target="_blank"
                    rel="noreferrer"
                    class="group flex flex-col gap-0.5 -mx-2 px-2 py-1 rounded-lg sm:flex-row sm:items-baseline sm:justify-between sm:gap-4 transition-colors hover:bg-emerald-50/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/40"
                  >
                    <span class="text-[13px] text-zinc-500 group-hover:text-emerald-700 transition-colors">
                      {post.title}<span class="sr-only"> (opens in a new tab)</span>
                    </span>
                    <time datetime={post.date} class="shrink-0 text-[11px] font-mono text-zinc-400">{fmtMaybe(post.date)}</time>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <a
          href="https://medium.com/@meftunakarsu"
          target="_blank"
          rel="noreferrer"
          class="group mt-6 inline-flex items-center gap-1 rounded text-xs text-zinc-400 hover:text-emerald-600 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/40"
        >
          All posts on Medium<span class="sr-only"> (opens in a new tab)</span>
          <span aria-hidden="true" class="group-hover:translate-x-0.5 transition-transform">&rarr;</span>
        </a>
      </section>

      <section class="mb-20">
        <h2 class="text-xs font-medium text-zinc-600 uppercase tracking-widest mb-8">Publications</h2>
        <div class="space-y-5">
          {PUBLICATIONS.map(pub => (
            <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-0">
              <span class="text-xs text-zinc-400 sm:w-16 shrink-0 font-mono">{pub.year}</span>
              <div class="flex-1">
                {pub.link ? (
                  <a href={pub.link} target="_blank" rel="noreferrer" class="text-sm text-zinc-400 hover:text-emerald-600 leading-snug">
                    {pub.title}
                  </a>
                ) : (
                  <span class="text-sm text-zinc-400 leading-snug">{pub.title}</span>
                )}
                <span class="text-xs text-zinc-600 ml-2">{pub.venue}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-xs font-medium text-zinc-600 uppercase tracking-widest mb-6">Certifications</h2>
        <div class="space-y-1.5">
          {CERTIFICATIONS.map((cert) => (
            <p class="text-xs text-zinc-600">{cert}</p>
          ))}
        </div>
      </section>

      <footer class="pt-8 border-t border-zinc-200">
        <p class="text-xs text-zinc-400">&copy; {new Date().getFullYear()} Meftun Akarsu</p>
      </footer>

    </div>
  </div>
</Layout>
