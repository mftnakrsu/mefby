---
import Layout from './Layout.astro';

interface SeriesLink {
  slug: string;
  title: string;
  seriesOrder?: number;
}
interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  lang?: string;
  slug?: string;
  summary?: string;
  translationSlug?: string;
  codeUrl?: string;
  ogImage?: string;
  series?: 'rag' | 'agents';
  seriesOrder?: number;
  seriesTotal?: number | null;
  prevEssay?: SeriesLink | null;
  nextEssay?: SeriesLink | null;
}
const { title, description, date, tags = [], lang = 'en', slug, summary, translationSlug, codeUrl, ogImage, series = 'rag', seriesOrder, seriesTotal, prevEssay, nextEssay } = Astro.props;
const dateFormatted = date.toISOString().slice(0, 10);

const backLabel = lang === 'tr' ? 'geri' : 'back';
const langs = ['en', 'tr'] as const;

const SERIES_META = {
  rag: { en: 'RAG FROM FIRST PRINCIPLES', tr: 'RAG: İLK İLKELERDEN', hub: '/essays/rag' },
  agents: { en: 'AGENTS FROM FIRST PRINCIPLES', tr: 'AJANLAR: İLK İLKELERDEN', hub: '/essays/agents' },
} as const;
const sm = SERIES_META[series] ?? SERIES_META.rag;
const inSeries = seriesOrder != null && seriesTotal != null;
const seriesLabel = lang === 'tr'
  ? `${sm.tr} · BÖLÜM ${seriesOrder} / ${seriesTotal}`
  : `${sm.en} · PART ${seriesOrder} OF ${seriesTotal}`;

const abs = (path: string) => new URL(path, Astro.site).toString();
const canonicalUrl = slug ? abs(`/essays/${slug}/`) : abs(Astro.url.pathname);
const metaDescription = summary ?? description;
const ogImageUrl = ogImage ? abs(ogImage) : undefined;

// hreflang alternates for a translated pair: self, counterpart, and x-default → EN.
const counterpartLang = lang === 'en' ? 'tr' : 'en';
const alternates = (translationSlug && slug)
  ? [
      { hreflang: lang, href: abs(`/essays/${slug}/`) },
      { hreflang: counterpartLang, href: abs(`/essays/${translationSlug}/`) },
      { hreflang: 'x-default', href: abs(`/essays/${lang === 'en' ? slug : translationSlug}/`) },
    ]
  : [];

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: metaDescription,
  datePublished: dateFormatted,
  dateModified: dateFormatted,
  inLanguage: lang,
  mainEntityOfPage: canonicalUrl,
  keywords: tags.join(", "),
  ...(ogImageUrl ? { image: ogImageUrl } : {}),
  author: {
    "@type": "Person",
    name: "Meftun Akarsu",
    url: "https://mefby.vercel.app",
    sameAs: [
      "https://www.linkedin.com/in/meftunakarsu/",
      "https://github.com/mftnakrsu",
    ],
  },
  publisher: {
    "@type": "Organization",
    name: "Meftun Akarsu",
    logo: { "@type": "ImageObject", url: abs("/icon.png") },
  },
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: abs("/") },
    { "@type": "ListItem", position: 2, name: "Essays", item: abs("/essays/") },
    { "@type": "ListItem", position: 3, name: title, item: canonicalUrl },
  ],
};
---

<Layout
  title={title}
  description={metaDescription}
  lang={lang}
  ogImage={ogImage}
  ogType="article"
  publishedTime={dateFormatted}
  tags={tags}
  alternates={alternates}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <div class="min-h-screen bg-white text-zinc-500 font-sans">
    <div class="max-w-2xl mx-auto px-6 py-16 md:py-24">
      <div class="flex items-center justify-between mb-12">
        <a href="/" class="text-xs text-zinc-400 hover:text-emerald-600 transition-colors">&larr; {backLabel}</a>
        <div class="flex items-center gap-2">
          {codeUrl && (
            <a
              href={codeUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-[11px] font-mono px-2.5 py-1 rounded-full text-zinc-500 border border-zinc-200 hover:text-emerald-700 hover:border-emerald-300 transition-colors"
              aria-label="View the code and step-by-step notebook for this essay on GitHub"
            >Code <span aria-hidden="true">&#8599;</span></a>
          )}
          {translationSlug && (
          <nav class="flex items-center gap-1" aria-label="Language">
            {langs.map((code) => (
              lang === code ? (
                <span
                  class="text-[11px] font-mono px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-700 border border-emerald-200"
                  aria-current="true"
                >{code.toUpperCase()}</span>
              ) : (
                <a
                  href={`/essays/${translationSlug}`}
                  class="text-[11px] font-mono px-2.5 py-1 rounded-full text-zinc-400 border border-transparent hover:text-emerald-600 hover:border-zinc-200 transition-colors"
                  aria-label={code === 'tr' ? 'Türkçe oku' : 'Read in English'}
                >{code.toUpperCase()}</a>
              )
            ))}
          </nav>
          )}
        </div>
      </div>

      <article lang={lang}>
        {inSeries && (
          <a href={sm.hub} class="inline-block text-[11px] font-mono uppercase tracking-widest text-emerald-700 hover:text-emerald-800 transition-colors mb-3">{seriesLabel}</a>
        )}
        <p class="text-xs font-mono text-zinc-400 mb-3 tracking-wider">{dateFormatted}</p>
        <h1 class="text-2xl sm:text-[28px] font-semibold text-zinc-900 leading-[1.25] tracking-tight mb-6">{title}</h1>
        <p class="text-[15px] text-zinc-600 italic leading-relaxed border-l-2 border-emerald-400 pl-4 mb-10">{description}</p>

        <div class="prose-essay">
          <slot />
        </div>

        {tags.length > 0 && (
          <div class="mt-12 pt-6 border-t border-zinc-100 flex flex-wrap gap-2">
            {tags.map(tag => (
              <span class="text-[11px] font-mono text-zinc-500 bg-zinc-50 border border-zinc-200 px-2.5 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        )}
      </article>

      {inSeries && (prevEssay || nextEssay) && (
        <nav class="mt-14 pt-8 border-t border-zinc-100 grid grid-cols-2 gap-4" aria-label="Series navigation">
          {prevEssay ? (
            <a href={`/essays/${prevEssay.slug}`} class="group block rounded-lg -m-2 p-2 transition-colors hover:bg-emerald-50/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/40">
              <span class="block text-[11px] font-mono uppercase tracking-wider text-zinc-400">&larr; Part {prevEssay.seriesOrder}</span>
              <span class="block mt-1 text-[13px] font-medium text-zinc-700 group-hover:text-emerald-700 transition-colors">{prevEssay.title}</span>
            </a>
          ) : <span></span>}
          {nextEssay ? (
            <a href={`/essays/${nextEssay.slug}`} class="group block rounded-lg -m-2 p-2 text-right transition-colors hover:bg-emerald-50/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/40">
              <span class="block text-[11px] font-mono uppercase tracking-wider text-zinc-400">Part {nextEssay.seriesOrder} &rarr;</span>
              <span class="block mt-1 text-[13px] font-medium text-zinc-700 group-hover:text-emerald-700 transition-colors">{nextEssay.title}</span>
            </a>
          ) : <span></span>}
        </nav>
      )}
    </div>
  </div>
</Layout>

<style is:global>
  .prose-essay {
    color: rgb(82 82 91);
    font-size: 15px;
    line-height: 1.75;
  }
  .prose-essay p { margin-bottom: 1.25rem; }
  .prose-essay h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: rgb(24 24 27);
    margin-top: 3rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }
  .prose-essay h3 {
    font-size: 1rem;
    font-weight: 600;
    color: rgb(24 24 27);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-essay strong { color: rgb(24 24 27); font-weight: 600; }
  .prose-essay code {
    background-color: rgb(244 244 245);
    color: rgb(4 120 87);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    font-family: ui-monospace, monospace;
  }
  /* Fenced code blocks: a light, bordered surface that matches the palette. */
  .prose-essay pre {
    position: relative;
    background-color: #f8fafc !important;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 1rem 1.15rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    font-size: 13.5px;
    line-height: 1.65;
  }
  /* Copy-to-clipboard button injected per code block (see the script below). */
  .essay-copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font: 600 11px ui-monospace, SFMono-Regular, Menlo, monospace;
    color: #64748b;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 2px 8px;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s, color 0.15s, border-color 0.15s;
  }
  .prose-essay pre:hover .essay-copy-btn,
  .essay-copy-btn:focus-visible { opacity: 1; }
  .essay-copy-btn:hover { color: #047857; border-color: #6ee7b7; }
  /* Reset the inline-code styling inside fenced blocks so Shiki's token
     colors show on the block surface (more specific than .prose-essay code). */
  .prose-essay pre code {
    background-color: transparent;
    color: inherit;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  /* On narrow screens, wrap long code lines rather than forcing a second scroll axis. */
  @media (max-width: 640px) {
    .prose-essay pre code { white-space: pre-wrap; word-break: break-word; }
  }
  .prose-essay ul {
    margin-bottom: 1.5rem;
    padding-left: 0.25rem;
  }
  .prose-essay ul li {
    padding-left: 1.25rem;
    margin-bottom: 0.625rem;
    position: relative;
    line-height: 1.7;
  }
  .prose-essay ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 0.5rem;
    height: 1px;
    background-color: rgb(52 211 153);
  }
  .prose-essay em { font-style: italic; }
  .prose-essay a { color: rgb(4 120 87); text-decoration: underline; }
  /* Tables: clean, bordered, on-palette (used from Part 3 onward). */
  .prose-essay table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.75rem 0;
    font-size: 14px;
    line-height: 1.55;
    display: block;
    overflow-x: auto;
  }
  .prose-essay th,
  .prose-essay td {
    border: 1px solid #e2e8f0;
    padding: 0.5rem 0.7rem;
    text-align: left;
    vertical-align: top;
  }
  .prose-essay thead th {
    background-color: #f1f5f9;
    color: rgb(24 24 27);
    font-weight: 600;
    white-space: nowrap;
  }
  .prose-essay tbody td code { white-space: nowrap; }
  .prose-essay blockquote {
    border-left: 2px solid rgb(52 211 153);
    padding-left: 1.25rem;
    margin: 1.75rem 0;
    color: rgb(63 63 70);
    font-style: italic;
  }
  .prose-essay blockquote p { margin-bottom: 0.75rem; }
  .prose-essay blockquote p:last-child { margin-bottom: 0; }
  .prose-essay blockquote strong { font-style: normal; }
</style>

<script>
  // Add a copy-to-clipboard button to every fenced code block.
  document.querySelectorAll<HTMLPreElement>('.prose-essay pre').forEach((pre) => {
    const code = pre.querySelector('code');
    if (!code) return;
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'essay-copy-btn';
    btn.textContent = 'Copy';
    btn.setAttribute('aria-label', 'Copy code to clipboard');
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(code.innerText);
        btn.textContent = 'Copied';
      } catch {
        btn.textContent = 'Failed';
      }
      setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
    });
    pre.appendChild(btn);
  });
</script>
