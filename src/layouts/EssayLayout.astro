---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
}
const { title, description, date, tags = [] } = Astro.props;
const dateFormatted = date.toISOString().slice(0, 10);

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  datePublished: dateFormatted,
  author: { "@type": "Person", name: "Meftun Akarsu" },
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <div class="min-h-screen bg-white text-zinc-500 font-sans">
    <div class="max-w-2xl mx-auto px-6 py-16 md:py-24">
      <a href="/" class="text-xs text-zinc-400 hover:text-emerald-600 transition-colors mb-12 inline-block">&larr; back</a>

      <article>
        <p class="text-xs font-mono text-zinc-400 mb-3 tracking-wider">{dateFormatted}</p>
        <h1 class="text-2xl sm:text-[28px] font-semibold text-zinc-900 leading-[1.25] tracking-tight mb-6">{title}</h1>
        <p class="text-[15px] text-zinc-600 italic leading-relaxed border-l-2 border-emerald-400 pl-4 mb-10">{description}</p>

        <div class="prose-essay">
          <slot />
        </div>

        {tags.length > 0 && (
          <div class="mt-12 pt-6 border-t border-zinc-100 flex flex-wrap gap-2">
            {tags.map(tag => (
              <span class="text-[11px] font-mono text-zinc-500 bg-zinc-50 border border-zinc-200 px-2.5 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        )}
      </article>
    </div>
  </div>
</Layout>

<style is:global>
  .prose-essay {
    color: rgb(82 82 91);
    font-size: 15px;
    line-height: 1.75;
  }
  .prose-essay p { margin-bottom: 1.25rem; }
  .prose-essay h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: rgb(24 24 27);
    margin-top: 3rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }
  .prose-essay h3 {
    font-size: 1rem;
    font-weight: 600;
    color: rgb(24 24 27);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-essay strong { color: rgb(24 24 27); font-weight: 600; }
  .prose-essay code {
    background-color: rgb(244 244 245);
    color: rgb(4 120 87);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    font-family: ui-monospace, monospace;
  }
  .prose-essay ul {
    margin-bottom: 1.5rem;
    padding-left: 0.25rem;
  }
  .prose-essay ul li {
    padding-left: 1.25rem;
    margin-bottom: 0.625rem;
    position: relative;
    line-height: 1.7;
  }
  .prose-essay ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 0.5rem;
    height: 1px;
    background-color: rgb(52 211 153);
  }
  .prose-essay em { font-style: italic; }
  .prose-essay a { color: rgb(4 120 87); text-decoration: underline; }
</style>
